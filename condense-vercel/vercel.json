{
  "buildCommand": "npx react-scripts build",
  "outputDirectory": "build",
  "env": {
    "CI": "false",
    "DISABLE_ESLINT_PLUGIN": "true"
  },
  "functions": {
    "api/gemini.js": {
      "maxDuration": 60
    },
    "api/enrich.js": {
      "maxDuration": 30
    },
    "api/zoho-push.js": {
      "maxDuration": 30
    },
    "api/linkedin.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
